# Пример 2: Добавляем клиента без телефона (поле phone примет значение NULL в базе)
add_new_client("Анна", "Петрова", "petrova@email.com")
    
def add_phone_number(client_id, new_phone):   
    conn = psycopg2.connect(
        database="Music_shop", user="postgres", password=""
    )
    with conn.cursor() as cur:
        # 2. Пишем SQL-запрос на обновление
        # %s — это плейсхолдеры, вместо которых встанут безопасные значения
        sql_query = """
            UPDATE clients 
            SET phone = %s 
            WHERE client_id = %s;
        """
        # 3. Выполняем запрос, передавая данные в кортеже (tuple)
        cur.execute(sql_query, (new_phone, client_id))

        # 4. Сохраняем изменения
        conn.commit()
        print(f"Телефон для клиента с ID {client_id} успешно обновлен!")

    # 5. Закрываем соединение
    conn.close()
    conn.close()

# ПРИМЕР ВЫЗОВА:
# Добавим телефон '+79991112233' клиенту, у которого id равен 1
add_phone_number(1, "+79991112233")

def change_clients_data(old_first_name, old_last_name, new_email, new_phone):
    conn = psycopg2.connect(
        database="Music_shop", user="postgres", password=""
    )
    try:
        with conn.cursor() as cur:
            sql_query = """
                UPDATE clients 
                SET email = %s,
                    phone = %s
                WHERE first_name = %s AND last_name = %s
                RETURNING *;
            """
            cur.execute(sql_query, (new_email, new_phone, old_first_name, old_last_name))
            updated_data = cur.fetchall()

            if not updated_data:
                print(f"Клиент {old_first_name} {old_last_name} не найден!")
            else:
                print(f"Данные обновлены для: {updated_data}")
        conn.commit()
    except errors.UniqueViolation:
        print(f"Ошибка: Email '{new_email}' уже занят другим клиентом!")
        conn.rollback()  # Откатываем транзакцию при ошибке [psycopg2.errors.UniqueViolation]
    finally:
        conn.close()

