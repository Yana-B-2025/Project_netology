import psycopg2
from psycopg2 import errors

def create_users_table():
    conn = psycopg2.connect(
        database="Music_shop", user="postgres", password=""
    )
    with conn.cursor() as cur:
        cur.execute(
            """
            CREATE TABLE IF NOT EXISTS clients (
                client_id SERIAL PRIMARY KEY,
                first_name VARCHAR(50) NOT NULL,   
                last_name VARCHAR(50) NOT NULL,    
                email VARCHAR(100) UNIQUE,         
                phone VARCHAR(20)                  
            );
        """
        )
    conn.commit()
    conn.close()
create_users_table()
   
def add_new_client(first_name, last_name, email, phone=None):   
    conn = psycopg2.connect(
        database="Music_shop", user="postgres", password=""
    )
    with conn.cursor() as cur:
        # 1. Указываем в какую таблицу и в какие колонки вставляем данные
        # 2. В VALUES пишем %s — безопасные плейсхолдеры для Python
        sql_query = """
            INSERT INTO clients (first_name, last_name, email, phone)
            VALUES (%s, %s, %s, %s)
            ON CONFLICT (email) DO NOTHING;
        """

        # 3. Передаем переменные в кортеже строго в том же порядке, что и %s
        cur.execute(sql_query, (first_name, last_name, email, phone))

        print(f"Клиент {first_name} {last_name} успешно добавлен!")

    conn.commit()
    conn.close()

# ПРИМЕРЫ ВЫЗОВА ФУНКЦИИ:

# Пример 1: Добавляем клиента со всеми данными
