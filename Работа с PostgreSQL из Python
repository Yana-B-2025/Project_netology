# Функция, позволяющая удалить телефон для существующего клиента.
def delete_phone(first_name, last_name):   
    conn = psycopg2.connect(
        database="Music_shop", user="postgres", password=""
    )
    with conn.cursor() as cur:
        # В конце добавляем RETURNING *, чтобы увидеть результат работы UPDATE
        sql_query = """
            UPDATE clients
            SET phone = NULL
            WHERE first_name = %s AND last_name = %s
            RETURNING *;
        """
        cur.execute(sql_query,(first_name, last_name))
        updated_data = cur.fetchall()

        # Проверяем, обновилось ли что-нибудь
        if not updated_data:
            print(f"Клиент {first_name} {last_name} не найден в базе!")
        else:
            print(f"Телефон успешно удален для всех тезок: {updated_data}")

    conn.commit()
    conn.close()

delete_phone("Анна", "Петрова")


