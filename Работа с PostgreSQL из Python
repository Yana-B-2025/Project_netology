# Функция, позволяющая удалить существующего клиента.
def delete_client(first_name, last_name):   
    conn = psycopg2.connect(
        database="Music_shop", user="postgres", password=""
    )
    with conn.cursor() as cur:
        sql_query = """
            DELETE FROM clients
            WHERE first_name = %s AND last_name = %s
            RETURNING *;
        """
        cur.execute(sql_query,(first_name, last_name))
        updated_data = cur.fetchall()

        # Проверяем, обновилось ли что-нибудь
        if not updated_data:
            print(f"Клиент {first_name} {last_name} не найден в базе!")
        else:
            print(f"Клиент {updated_data}")

    conn.commit()
    conn.close()

