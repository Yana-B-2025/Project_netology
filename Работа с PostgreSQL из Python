# Функция, позволяющая найти клиента по его данным: имени, фамилии, email или телефону.
def find_client(first_name, last_name, email, phone):   
    conn = psycopg2.connect(
        database="Music_shop", user="postgres", password=""
    )
    with conn.cursor() as cur:
        sql_query = """
            SELECT * FROM clients
            WHERE first_name = %s AND last_name = %s AND email = %s AND phone = %s;
        """
        cur.execute(sql_query,(first_name, last_name, email, phone))
        
        # Забираем ВСЕ найденные строки
        results = cur.fetchall()

        if not results:
            print("По вашему запросу ничего не найдено.")
        else:
            print(f"Найденные клиенты: {results}")


    conn.commit()
    conn.close()

find_client("Иван", "Иванов", "ivanov@email.com", "+79991112233")
